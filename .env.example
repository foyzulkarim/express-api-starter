# Node Environment
# Options: development, production, test
NODE_ENV=development

# Server Port
PORT=3000

# Database
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_api

# Redis
# Redis connection string
REDIS_URL=redis://localhost:6379

# Authentication
# JWT secret key (minimum 32 characters in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT token expiration time
JWT_EXPIRES_IN=15m

# Logging (Pino)
# Level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
# Pretty-printed logs (pino-pretty) are enabled when NODE_ENV=development (see src/config/logger.ts).
# Redaction: sensitive request fields and common secret keys are stripped in logs; paths are defined in
# src/config/logger.ts (e.g. req.headers.authorization, req.body.password, *.token, password, …).

# CORS
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*
